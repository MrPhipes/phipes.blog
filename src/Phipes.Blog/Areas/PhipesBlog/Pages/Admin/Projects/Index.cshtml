@page "/admin/blog/projects"
@model Phipes.Blog.Areas.PhipesBlog.Pages.Admin.Projects.IndexModel
@{
    ViewData["Title"] = "Proyectos";
}

<partial name="../Shared/_AdminNav" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Proyectos</h1>
    <a class="btn btn-primary" href="/admin/blog/projects/edit">+ Nuevo proyecto</a>
</div>

<table class="table table-hover align-middle">
    <thead>
        <tr><th>Título</th><th>Cliente</th><th>Destacado</th><th class="text-end">Acciones</th></tr>
    </thead>
    <tbody>
        @foreach (var p in Model.Projects.Items)
        {
            <tr>
                <td>
                    <a href="/admin/blog/projects/edit?id=@p.Id">@p.Title</a>
                    <div class="small text-muted">/@p.Slug</div>
                </td>
                <td class="small">@(p.ClientName ?? "—")</td>
                <td>@(p.IsFeatured ? "★" : "")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-secondary" href="/proyectos/@p.Slug" target="_blank">Ver</a>
                    <form method="post" asp-page-handler="Delete" class="d-inline"
                          onsubmit="return confirm('¿Eliminar este proyecto?');">
                        <input type="hidden" name="id" value="@p.Id" />
                        <button class="btn btn-sm btn-outline-danger">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
        @if (Model.Projects.TotalCount == 0)
        {
            <tr><td colspan="4" class="text-center text-muted py-4">No hay proyectos todavía.</td></tr>
        }
    </tbody>
</table>
