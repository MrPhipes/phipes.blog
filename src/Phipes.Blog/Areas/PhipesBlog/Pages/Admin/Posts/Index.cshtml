@page "/admin/posts"
@model Phipes.Blog.Areas.PhipesBlog.Pages.Admin.Posts.IndexModel
@{
    ViewData["Title"] = "Posts";
}

<partial name="../Shared/_AdminNav" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Posts</h1>
    <a class="btn btn-primary" href="/admin/posts/edit">+ Nuevo post</a>
</div>

<table class="table table-hover align-middle">
    <thead>
        <tr><th>Título</th><th>Estado</th><th>Publicado</th><th class="text-end">Acciones</th></tr>
    </thead>
    <tbody>
        @foreach (var p in Model.Posts.Items)
        {
            <tr>
                <td>
                    <a href="/admin/posts/edit?id=@p.Id">@p.Title</a>
                    <div class="small text-muted">/@p.Slug</div>
                </td>
                <td><span class="badge text-bg-secondary">@p.Categories.FirstOrDefault()</span></td>
                <td class="small">@(p.PublishedAt?.ToString("dd MMM yyyy") ?? "—")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-secondary" href="/blog/@p.Slug" target="_blank">Ver</a>
                    <form method="post" asp-page-handler="Delete" class="d-inline"
                          onsubmit="return confirm('¿Eliminar este post?');">
                        <input type="hidden" name="id" value="@p.Id" />
                        <button class="btn btn-sm btn-outline-danger">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
        @if (Model.Posts.TotalCount == 0)
        {
            <tr><td colspan="4" class="text-center text-muted py-4">No hay posts todavía.</td></tr>
        }
    </tbody>
</table>
