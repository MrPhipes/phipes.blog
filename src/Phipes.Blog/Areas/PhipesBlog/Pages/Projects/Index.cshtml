@page "/proyectos"
@model Phipes.Blog.Areas.PhipesBlog.Pages.Projects.IndexModel
@{
    ViewData["Title"] = "Proyectos";
}

<header class="pb-page-head text-center mb-5">
    <h1 class="pb-page-title">Proyectos</h1>
    <p class="lead text-muted">Casos reales: el problema del negocio, qué construí y qué cambió después.</p>
</header>

@if (Model.Projects.TotalCount == 0)
{
    <p class="text-muted text-center">Aún no hay proyectos publicados.</p>
}
else
{
    <div class="row g-4 pb-portfolio">
        @foreach (var p in Model.Projects.Items)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <a class="pb-portfolio-card card h-100 border-0 shadow-sm text-decoration-none" href="/proyectos/@p.Slug">
                    <div class="pb-portfolio-media">
                        @if (!string.IsNullOrEmpty(p.CoverImageUrl))
                        {
                            <img src="@p.CoverImageUrl" alt="@p.Title" loading="lazy" />
                        }
                        else
                        {
                            <div class="pb-portfolio-placeholder"><i class="fas fa-diagram-project"></i></div>
                        }
                        @if (p.IsFeatured)
                        {
                            <span class="pb-portfolio-ribbon">Destacado</span>
                        }
                        <div class="pb-portfolio-overlay"><span>Ver caso <i class="fas fa-arrow-right"></i></span></div>
                    </div>
                    <div class="card-body">
                        <h2 class="h5 pb-portfolio-title">@p.Title</h2>
                        @if (!string.IsNullOrEmpty(p.Outcome))
                        {
                            <p class="pb-portfolio-outcome"><i class="fas fa-arrow-trend-up"></i> @p.Outcome</p>
                        }
                        <p class="pb-portfolio-summary text-muted">@p.Summary</p>
                        <div class="pb-portfolio-tech">
                            @foreach (var tech in p.TechStack.Take(4))
                            {
                                <span class="pb-chip">@tech</span>
                            }
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
