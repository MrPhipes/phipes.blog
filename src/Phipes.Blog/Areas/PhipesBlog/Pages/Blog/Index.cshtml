@page "/blog"
@model Phipes.Blog.Areas.PhipesBlog.Pages.Blog.IndexModel
@{
    ViewData["Title"] = "Blog";
}

<header class="pb-page-head text-center mb-5">
    <h1 class="pb-page-title">Blog</h1>
    <p class="lead text-muted">Notas técnicas, lecciones del homelab y cosas que vale la pena documentar.</p>
</header>

@if (Model.Posts.TotalCount == 0)
{
    <p class="text-muted text-center">Aún no hay entradas publicadas.</p>
}
else
{
    <div class="row g-4 pb-bloglist">
        @foreach (var post in Model.Posts.Items)
        {
            <div class="col-12 col-md-6">
                <article class="pb-postcard card h-100 border-0 shadow-sm">
                    @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                    {
                        <a href="/blog/@post.Slug" class="pb-postcard-media">
                            <img src="@post.CoverImageUrl" alt="@post.Title" loading="lazy" />
                        </a>
                    }
                    <div class="card-body d-flex flex-column">
                        <div class="pb-postcard-meta">
                            @foreach (var c in post.Categories.Take(1))
                            {
                                <span class="pb-cat">@c</span>
                            }
                            <span class="pb-date">@(post.PublishedAt?.ToString("dd MMM yyyy"))</span>
                            <span class="pb-readtime">· @post.ReadingMinutes min</span>
                        </div>
                        <h2 class="h4 pb-postcard-title">
                            <a href="/blog/@post.Slug">@post.Title</a>
                        </h2>
                        <p class="pb-postcard-excerpt text-muted flex-grow-1">@post.Summary</p>
                        <a class="pb-readmore" href="/blog/@post.Slug">Leer más <i class="fas fa-arrow-right"></i></a>
                    </div>
                </article>
            </div>
        }
    </div>

    @if (Model.Posts.TotalPages > 1)
    {
        <nav class="mt-5">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Posts.HasPrevious ? "" : "disabled")">
                    <a class="page-link" href="?page=@(Model.PageNumber - 1)">Anterior</a>
                </li>
                <li class="page-item disabled"><span class="page-link">@Model.PageNumber / @Model.Posts.TotalPages</span></li>
                <li class="page-item @(Model.Posts.HasNext ? "" : "disabled")">
                    <a class="page-link" href="?page=@(Model.PageNumber + 1)">Siguiente</a>
                </li>
            </ul>
        </nav>
    }
}
