@inject Microsoft.Extensions.Options.IOptions<Phipes.Blog.PhipesBlogOptions> BlogOptions
@{
    var o = BlogOptions.Value;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/_content/Phipes.Blog/css/phipes-blog.css" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-md navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Phipes</a>
            <ul class="navbar-nav flex-row gap-3">
                <li class="nav-item"><a class="nav-link" href="@o.PublicRoutePrefix">Blog</a></li>
                <li class="nav-item"><a class="nav-link" href="/proyectos">Proyectos</a></li>
                <li class="nav-item"><a class="nav-link" href="/sobre-mi">Sobre mí</a></li>
                <li class="nav-item"><a class="nav-link" href="/contacto">Contacto</a></li>
            </ul>
        </div>
    </nav>

    <main class="container py-4 flex-grow-1">
        @RenderBody()
    </main>

    <footer class="bg-light border-top py-3 mt-auto">
        <div class="container text-muted small d-flex justify-content-between">
            <span>© @DateTime.Now.Year Phipes</span>
            <span>Powered by Phipes.Blog</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
